# =============================================================================
# PETR4 Price Predictor — .gitignore
# =============================================================================

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
.eggs/

# Virtual environments
.venv/
venv/
ENV/
env/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data files — raw and processed data are not committed
data/raw/*.csv
data/raw/*.parquet
data/processed/*.csv
data/processed/*.parquet
data/processed/*.npy
data/predictions/*.csv
data/predictions/*.json

# Trained models (large binary files — use DVC or cloud storage)
models/trained/*.keras
models/trained/*.h5
models/trained/*.pkl
models/artifacts/*.pkl
models/artifacts/*.json

# Logs
logs/
*.log

# Environment variables
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Testing / coverage
.coverage
htmlcov/
.pytest_cache/
coverage.xml

# Docker
*.tar

# Temporary
tmp/
temp/
